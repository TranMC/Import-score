{
    "columns": {
        "name": "Tên Học Sinh",
        "exam_code": "Mã đề",
        "score": "Điểm"
    },
    "max_questions": 111,
    "score_per_question": 0.09,
    "exam_codes": [
        "701",
        "702",
        "703",
        "704",
        "601",
        "602",
        "603",
        "604"
    ],
    "shortcuts": {
        "search": "<Control-f>",
        "direct_score": "<Control-g>",
        "undo": "<Control-z>"
    },
    "security": {
        "encrypt_backups": false,
        "encrypt_sensitive_data": false,
        "password_protect_app": false,
        "auto_lock_timeout_minutes": 0
    },
    "ui": {
        "font_family": "Segoe UI",
        "font_size": {
            "normal": 11,
            "heading": 12,
            "button": 11
        },
        "padding": {
            "frame": 10,
            "widget": 5
        },
        "min_width": {
            "button": 120,
            "entry": 150,
            "combobox": 100
        },
        "theme": {
            "primary": "#7C3AED",
            "primary_dark": "#6D28D9",
            "secondary": "#10B981",
            "accent": "#EC4899",
            "warning": "#FBBF24",
            "error": "#EF4444",
            "success": "#34D399",
            "info": "#3B82F6",
            "text": "#F9FAFB",
            "text_secondary": "#D1D5DB",
            "background": "#111827",
            "card": "#1F2937",
            "card_hover": "#374151",
            "border": "#374151",
            "hover": "#374151",
            "active": "#6D28D9",
            "selected": "#A78BFA",
            "treeview_bg": "#1F2937",
            "treeview_selected": "#7C3AED",
            "treeview_hover": "#374151",
            "disabled": "#6B7280",
            "gradient_start": "#7C3AED",
            "gradient_end": "#EC4899",
            "shadow": "#00000040",
            "old_background": "#111827",
            "old_primary": "#7C3AED"
        },
        "rounded_corners": 4,
        "row_striping": true,
        "animation": true,
        "dark_mode": true,
        "responsive": {
            "initial_width": 1920,
            "initial_height": 1080,
            "min_width": 1480,
            "min_height": 920
        }
    },
    "auto_backup": true,
    "update_channel": "dev",
    "excel_reading": {
        "header_detection": {
            "enabled": true,
            "max_search_rows": 50,
            "multi_level_support": true,
            "merge_separator": "_",
            "min_columns_match": 3,
            "validate_data_rows": true
        },
        "column_patterns": {
            "student_info": {
                "stt": {
                    "patterns": ["STT", "Số TT", "Số thứ tự", "TT"],
                    "regex": "^(STT|Số\\s*TT|Số\\s*thứ\\s*tự|TT)$",
                    "required": false
                },
                "student_id": {
                    "patterns": ["Mã định danh", "Mã HS", "MSSV", "Mã số", "ID", "Số báo danh"],
                    "regex": "^(Mã\\s*định\\s*danh|Mã\\s*HS|MSSV|Mã\\s*số|ID|Số\\s*báo\\s*danh)",
                    "required": false
                },
                "name": {
                    "patterns": ["Họ và tên", "Tên học sinh", "Họ tên", "Tên", "Học sinh"],
                    "regex": "^(Họ\\s*và\\s*tên|Tên\\s*học\\s*sinh|Họ\\s*tên|Tên|Học\\s*sinh)",
                    "required": true
                },
                "dob": {
                    "patterns": ["Ngày sinh", "Sinh nhật", "DOB"],
                    "regex": "^(Ngày\\s*sinh|Sinh\\s*nhật|DOB)",
                    "required": false
                },
                "gender": {
                    "patterns": ["Giới tính", "Phái", "Nam/Nữ", "Sex"],
                    "regex": "^(Giới\\s*tính|Phái|Nam\\s*/\\s*Nữ|Sex)",
                    "required": false
                }
            },
            "score_columns": {
                "ddgtx": {
                    "patterns": ["ĐĐGtx", "Điểm TX", "Điểm thường xuyên", "TX"],
                    "regex": "^(ĐĐGtx|Điểm\\s*TX|Điểm\\s*thường\\s*xuyên|TX)[\\s_-]*(\\d*)$",
                    "has_sub_columns": true,
                    "sub_column_pattern": "^(\\d+)$",
                    "description": "Điểm đánh giá thường xuyên"
                },
                "ddggk": {
                    "patterns": ["ĐĐGgk", "ĐĐGgiữa kỳ", "Điểm GK", "Điểm giữa kỳ", "GK"],
                    "regex": "^(ĐĐGgk|ĐĐGgiữa\\s*kỳ|Điểm\\s*GK|Điểm\\s*giữa\\s*kỳ|GK)$",
                    "has_sub_columns": false,
                    "description": "Điểm đánh giá giữa kỳ"
                },
                "ddgck": {
                    "patterns": ["ĐĐGck", "ĐĐGcuối kỳ", "Điểm CK", "Điểm cuối kỳ", "CK"],
                    "regex": "^(ĐĐGck|ĐĐGcuối\\s*kỳ|Điểm\\s*CK|Điểm\\s*cuối\\s*kỳ|CK)$",
                    "has_sub_columns": false,
                    "description": "Điểm đánh giá cuối kỳ"
                },
                "dtbmhki": {
                    "patterns": ["ĐTBmhkI", "ĐTB HK1", "Điểm TB HK1", "Điểm trung bình HK1"],
                    "regex": "^(ĐTBmhkI|ĐTB\\s*HK1|Điểm\\s*TB\\s*HK1|Điểm\\s*trung\\s*bình\\s*HK1)$",
                    "has_sub_columns": false,
                    "description": "Điểm trung bình môn học kỳ I"
                }
            }
        },
        "merged_cell_handling": {
            "enabled": true,
            "forward_fill": true,
            "combine_with_subheader": true,
            "cache_merged_info": true
        },
        "performance": {
            "enable_caching": true,
            "cache_max_files": 3,
            "cache_search_results": true,
            "cache_stats": true
        }
    }
}